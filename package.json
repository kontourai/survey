{
  "name": "@kontourai/survey",
  "version": "0.4.23",
  "description": "Producer-side source, extraction, candidate, and review contracts for projecting verified claims into Surface.",
  "license": "Apache-2.0",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/survey.git"
  },
  "homepage": "https://kontourai.io/survey",
  "bugs": {
    "url": "https://github.com/kontourai/survey/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/src/index.js",
    "./review-workbench": {
      "types": "./dist/src/review-workbench/review-workbench.d.ts",
      "default": "./dist/src/review-workbench/review-workbench.js"
    },
    "./review-workbench/server-review-session": {
      "types": "./dist/src/review-workbench/server-review-session.d.ts",
      "default": "./dist/src/review-workbench/server-review-session.js"
    },
    "./review-workbench.css": "./dist/src/review-workbench/review-workbench.css",
    "./review-workbench/standalone.css": "./dist/src/review-workbench/review-workbench.standalone.css",
    "./fixtures/public-field-review": "./dist/fixtures/public-field-review.js",
    "./fixtures/corrected-document-candidates": "./dist/fixtures/corrected-document-candidates.js",
    "./fixtures/public-directory-review-resource": "./dist/fixtures/public-directory-review-resource.js",
    "./fixtures/regulated-document-review-resource": "./dist/fixtures/regulated-document-review-resource.js"
  },
  "files": [
    "dist/examples/",
    "dist/fixtures/",
    "dist/src/",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && node scripts/copy-review-workbench-package-assets.cjs",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "test:browser": "playwright test",
    "verify": "node scripts/check-content-boundary.cjs && npm run typecheck && npm test && npm run check:review-workbench-assets && npm run check:review-workbench && npm run test:browser",
    "check:content-boundary": "node scripts/check-content-boundary.cjs",
    "sync:review-workbench-assets": "node scripts/sync-review-workbench-assets.cjs",
    "check:review-workbench-assets": "node scripts/sync-review-workbench-assets.cjs --check",
    "check:review-workbench": "npm run check:review-workbench:static",
    "check:review-workbench:static": "npm run build && node scripts/check-review-workbench.cjs",
    "setup:repo-hooks": "node scripts/setup-repo-hooks.cjs",
    "validate:repo-hooks": "node scripts/validate-repo-hooks.cjs"
  },
  "dependencies": {
    "@kontourai/surface": "^0.5.1"
  },
  "devDependencies": {
    "@kontourai/console-kit": "^0.1.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
