{
  "name": "@kontourai/survey",
  "version": "1.2.1",
  "description": "Producer-side source, extraction, candidate, and review contracts for projecting verified claims into Surface.",
  "license": "Apache-2.0",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/survey.git"
  },
  "homepage": "https://kontourai.github.io/survey/",
  "bugs": {
    "url": "https://github.com/kontourai/survey/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/src/index.js",
    "./anthropic": {
      "types": "./dist/src/anthropic.d.ts",
      "default": "./dist/src/anthropic.js"
    },
    "./review-workbench": {
      "types": "./dist/src/review-workbench/review-workbench.d.ts",
      "default": "./dist/src/review-workbench/review-workbench.js"
    },
    "./review-workbench/element": {
      "types": "./dist/src/review-workbench/review-workbench-element.d.ts",
      "default": "./dist/src/review-workbench/review-workbench-element.js"
    },
    "./review-workbench/server-review-session": {
      "types": "./dist/src/review-workbench/server-review-session.d.ts",
      "default": "./dist/src/review-workbench/server-review-session.js"
    },
    "./review-workbench.css": "./dist/src/review-workbench/review-workbench.css",
    "./review-workbench/standalone.css": "./dist/src/review-workbench/review-workbench.standalone.css",
    "./example-data/public-field-review": "./dist/example-data/public-field-review.js",
    "./example-data/corrected-document-candidates": "./dist/example-data/corrected-document-candidates.js",
    "./example-data/public-directory-review-resource": "./dist/example-data/public-directory-review-resource.js",
    "./example-data/regulated-document-review-resource": "./dist/example-data/regulated-document-review-resource.js"
  },
  "files": [
    "bin/",
    "dist/examples/",
    "dist/example-data/",
    "dist/src/",
    "README.md",
    "example-data/mcp-review-session.json"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && node scripts/copy-review-workbench-package-assets.cjs",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "test:browser": "playwright test",
    "verify": "node scripts/check-content-boundary.cjs && npm run typecheck && npm test && npm run check:review-workbench-assets && npm run check:review-workbench && npm run test:browser",
    "check:content-boundary": "node scripts/check-content-boundary.cjs",
    "sync:review-workbench-assets": "node scripts/sync-review-workbench-assets.cjs",
    "check:review-workbench-assets": "node scripts/sync-review-workbench-assets.cjs --check",
    "check:review-workbench": "npm run check:review-workbench:static && npm run check:generated-css",
    "check:review-workbench:static": "npm run build && node scripts/check-review-workbench.cjs",
    "setup:repo-hooks": "node scripts/setup-repo-hooks.cjs",
    "validate:repo-hooks": "node scripts/validate-repo-hooks.cjs",
    "docs:build": "npm run build --silent && node scripts/docs-site/build.ts",
    "docs:check": "npm run docs:build && node scripts/docs-site/check-links.ts",
    "check:generated-css": "node scripts/copy-review-workbench-package-assets.cjs --check"
  },
  "dependencies": {
    "@kontourai/surface": "^1.3.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@kontourai/ui": "^1.1.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.0",
    "marked": "^16.4.2",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "survey-review-mcp": "./bin/survey-review-mcp.mjs",
    "survey-review-console": "./bin/survey-review-console.mjs"
  }
}
